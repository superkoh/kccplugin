{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kccplugin/hooks.schema.json",
  "title": "Plugin hooks.json",
  "description": "Strict schema for <plugin>/hooks/hooks.json.",
  "type": "object",
  "additionalProperties": false,
  "required": ["hooks"],
  "properties": {
    "hooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "PreToolUse":       { "$ref": "#/definitions/hookList" },
        "PostToolUse":      { "$ref": "#/definitions/hookList" },
        "UserPromptSubmit": { "$ref": "#/definitions/hookList" },
        "Notification":     { "$ref": "#/definitions/hookList" },
        "Stop":             { "$ref": "#/definitions/hookList" },
        "SubagentStop":     { "$ref": "#/definitions/hookList" },
        "PreCompact":       { "$ref": "#/definitions/hookList" },
        "SessionStart":     { "$ref": "#/definitions/hookList" },
        "SessionEnd":       { "$ref": "#/definitions/hookList" }
      }
    }
  },
  "definitions": {
    "hookList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hooks"],
        "properties": {
          "matcher": { "type": "string" },
          "hooks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "command"],
              "properties": {
                "type": { "type": "string", "enum": ["command"] },
                "command": { "type": "string", "minLength": 1 },
                "timeout": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    }
  }
}
