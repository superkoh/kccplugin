{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "kccplugin/agent-frontmatter.schema.json",
  "title": "Sub-agent YAML frontmatter",
  "description": "Strict schema for YAML frontmatter in agents/<name>.md files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "description"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "description": { "type": "string", "minLength": 1 },
    "model": { "type": "string" },
    "effort": {
      "type": "string",
      "enum": ["low", "medium", "high", "max"]
    },
    "maxTurns": { "type": "integer", "minimum": 1 },
    "tools": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "disallowedTools": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    }
  }
}
